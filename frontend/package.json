    "lucide-vue-next": "^0.553.0",
    "mammoth": "^1.11.0",
    "pinia": "^2.3.1",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.24",
    "frontend": "file:",
    "vue-router": "^4.6.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
